  "paths": {
    "/EMAP_ROAD": {
      "get": {
        "operationId": "EMAP_WFS_001",
        "summary": "取得臺灣通用電子地圖道路(道路中線)",
        "description": "取得臺灣通用電子地圖道路(道路中線)",
        "tags": [ 
          "道路"
        ],
        "x-updateTime": "2026-06-12T15:30:23+08:00",
        "parameters": [ 
          {
            "name": "SERVICE",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "WFS"
              ]
            },
            "description": "服務類型，固定為 WFS"
          },
          {
            "name": "REQUEST",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "GetFeature"
              ]
            },
            "description": "請求操作類型"
          },
          {
            "name": "VERSION",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "1.3.0"
            },
            "description": "WFS 版本"
          },
          {
            "name": "SRSName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "EPSG:3857"
            },
            "description": "座標參考系統"
          },
          {
            "name": "BBOX",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "121.0,24.0,122.0,25.0"
            },
            "description": "邊界框 (minX,minY,maxX,maxY)"
          },
          {
            "name": "outputFormat",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "GML"
              ]
            },
            "description": "請求操作類型"
          }
        ],
        "responses": {
          "200": {
            "description": "成功回傳WFS資料",
            "content": {
              "application/gml+xml": {
                "schema": {
                  "type": "string"	
                }
              }            
            }
          },
          "400": {
            "description": "參數錯誤"
          }
        }
      }
    },
